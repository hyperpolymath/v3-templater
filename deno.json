{
  "name": "@hyperpolymath/v3-templater",
  "version": "1.0.0",
  "description": "A modern, secure, and high-performance templating engine",
  "license": "MPL-2.0",
  "homepage": "https://github.com/hyperpolymath/v3-templater",
  "repository": "https://github.com/hyperpolymath/v3-templater",
  
  "exports": {
    ".": "./src/index.js",
    "./engine": "./src/engine.js"
  },
  
  "tasks": {
    "test": "deno test --allow-all tests/",
    "test:watch": "deno test --allow-all --watch tests/",
    "lint": "deno lint src/ tests/",
    "fmt": "deno fmt src/ tests/",
    "fmt:check": "deno fmt --check src/ tests/",
    "check": "deno check src/index.js",
    "bench": "deno run --allow-all src/benchmark.js",
    "docs": "deno doc src/index.js"
  },
  
  "compilerOptions": {
    "checkJs": false,
    "lib": ["deno.window", "deno.ns", "esnext"]
  },
  
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": true,
    "proseWrap": "preserve",
    "include": ["src/", "tests/"],
    "exclude": ["**/node_modules/", "**/dist/", "**/coverage/"]
  },
  
  "lint": {
    "include": ["src/", "tests/"],
    "exclude": ["**/node_modules/", "**/dist/", "**/coverage/"] ,
    "rules": {
      "tags": ["recommended"],
      "include": ["no-unused-vars", "no-undef"],
      "exclude": ["no-slow-types", "no-import-prefix"]
    }
  }
}
